// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // bcrypt 加密
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]
  conversations Conversation[]

  @@map("users")
}

model Document {
  id          String   @id @default(uuid())
  title       String
  content     String
  preview     String?
  
  // 关联用户
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 来源消息（可选）
  sourceMessageId String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("documents")
}

model Conversation {
  id        String   @id @default(uuid())
  title     String   @default("新对话")
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  messages  Message[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("conversations")
}

model Message {
  id              String   @id @default(uuid())
  role            MessageRole
  content         String
  
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())

  @@map("messages")
}

model Corpus {
  id          String   @id @default(uuid())
  title       String
  content     String   // SQLite 中 String 支持长文本
  category    String   // 文种类型：讲话稿、活动通知、工作总结等
  tags        String   @default("[]") // JSON字符串存储标签数组
  source      String?  // 来源
  isTemplate  Boolean  @default(false) // 是否为范文模板
  
  // 统计字段
  viewCount   Int      @default(0)  // 浏览次数
  useCount    Int      @default(0)  // 使用次数
  
  // RAG预留字段
  vectorId    String?  // 向量数据库ID（预留）
  // embedding 字段使用JSON字符串存储，兼容SQLite
  embedding   String?  // 向量嵌入数据（JSON字符串，预留）
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("corpus")
}

enum Role {
  USER
  ADMIN
}

enum MessageRole {
  user
  assistant
  system
}
